{
  "name": "buildflow",
  "version": "1.2.13-beta",
  "private": true,
  "description": "BuildFlow turns ideas into execution packets tailored to your actual local toolchain",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "generate:openapi-chatgpt": "node scripts/generate-openapi-chatgpt.mjs",
    "verify:dashboard": "node scripts/verify-dashboard.mjs",
    "local:verify:dashboard-only": "LOCAL_DASHBOARD_ONLY=true node scripts/verify-dashboard.mjs",
    "verify:gpt-actions": "node scripts/verify-custom-gpt-actions.mjs",
    "verify:gpt-contract": "node scripts/verify-custom-gpt-actions.mjs",
    "restart:local": "bash scripts/restart-buildflow-local.sh",
    "local:status": "bash scripts/buildflow-local-stack.sh status",
    "local:start": "bash scripts/buildflow-local-stack.sh start",
    "local:stop": "bash scripts/buildflow-local-stack.sh stop",
    "local:restart": "bash scripts/buildflow-local-stack.sh restart",
    "local:rebuild-web": "bash scripts/buildflow-local-stack.sh rebuild-web",
    "local:verify": "bash scripts/buildflow-local-stack.sh verify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
