{
  "openapi": "3.1.0",
  "info": {
    "title": "Read files",
    "version": "1.3.0",
    "description": "Batch read exact file paths."
  },
  "servers": [
    {
      "url": "https://buildflow.prochat.tools",
      "description": "BuildFlow public endpoint"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/api/actions/read-files": {
      "post": {
        "operationId": "readBuildFlowFiles",
        "summary": "Read files",
        "description": "Batch read exact file paths.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "sourceId": {
                    "type": "string",
                    "description": "Optional source id."
                  },
                  "sourceIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional source ids. If omitted, BuildFlow uses active sources.",
                    "minItems": 1,
                    "maxItems": 10
                  },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Exact relative paths returned by search or list.",
                    "minItems": 1,
                    "maxItems": 10
                  },
                  "maxBytesPerFile": {
                    "type": "integer",
                    "description": "Maximum bytes per file.",
                    "default": 30000,
                    "minimum": 1000,
                    "maximum": 60000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "files": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "sourceId": {
                            "type": "string"
                          },
                          "path": {
                            "type": "string"
                          },
                          "content": {
                            "type": "string"
                          },
                          "truncated": {
                            "type": "boolean"
                          },
                          "sizeBytes": {
                            "type": "integer"
                          },
                          "modifiedAt": {
                            "type": "string"
                          },
                          "error": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
